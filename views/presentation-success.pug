extends ./layout.pug

block head-styles
	link(rel="stylesheet" href="/styles/presentation-success.css")
	link(rel="stylesheet" href="/styles/spinner.css")
	link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/jsoneditor@10.2.0/dist/jsoneditor.min.css")
	link(rel="stylesheet" href="/styles/jsoneditor.css")

block layout-content
	section
		// Spinner / loading
		#spinner-container.presentation-status
			.spinner
				.spinner-circle

		#loading-text.presentation-status
			.container.presentation-status__container
				.presentation-status__header
					h2 #{locale.presentationSuccess.loading.title}
					p.presentation-status__subtitle #{locale.presentationSuccess.loading.subtitle}

		// Success (initially hidden)
		#success-container(style="display: none;")
			.container.container__flexed
				header.page__header
					h2 #{locale.presentationSuccess.title}

				// Credentials images
				.inline-box-container
					each credential, index in credentialPayloads
						- const branding = credential.credentialBranding || { backgroundColor: 'var(--primary-main-color)', textColor: '#fff' }
						.credential-box(id=`credential-box-${index}`)
							img.credential-image(src=credentialImages[index] alt=`Credential ${index + 1}`)

				// Verified timestamp
				p.presentation-success__meta
					i  #{locale.presentationSuccess.verifiedOn} #{new Date(verificationTimestamp)}

				// Claims extracted
				.card__container
					h2.presentation-success__sectionTitle #{locale.presentationSuccess.claims.title}
					.claims-tables
						each descriptorId in Object.keys(presentationClaims)
							.claims-block
								h3.claims-title= descriptorId

								.table-container
									table.claims-table
										thead
											tr
												th #{locale.presentationSuccess.claims.name}
												th #{locale.presentationSuccess.claims.value}
										tbody
											each claim in presentationClaims[descriptorId]
												tr
													td= claim.name
													td.claim-value(data-raw-value=String(claim.value))= claim.value

								if presentationInfo[descriptorId]
									.additional-info
										h4 #{locale.presentationSuccess.claims.additionalInfoTitle}
										each message in presentationInfo[descriptorId]
											p= message

				// JSON viewer
				.card__container
					details.details-toggle
						summary #{locale.presentationSuccess.json.title}
						.presentation-json__header
							button#copy-button.Btn.Btn--xs.presentation-json__copy(type="button")
								span.copy-state.copy-default
									span #{locale.presentationSuccess.json.copy}
									span.presentation-json__copyIcon(aria-hidden="true") ⧉
								span.copy-state.copy-success
									span #{locale.presentationSuccess.json.copied}
									span(aria-hidden="true") ✓
						div#jsoneditor.jsoneditor-host.wide


block body-scripts
	// Show spinner for 2 seconds then show success
	script(defer).
		setTimeout(() => {
			const spinnerContainer = document.getElementById('spinner-container');
			const successContainer = document.getElementById('success-container');
			const loadingText = document.getElementById('loading-text');

			if (spinnerContainer && successContainer && loadingText) {
				spinnerContainer.style.display = 'none';
				successContainer.style.display = 'block';
				loadingText.style.display = 'none';
			}
		}, 2000);

	script(src="https://cdn.jsdelivr.net/npm/jsoneditor@latest")
	script.
		const container = document.getElementById('jsoneditor');
		const options = {
			mode: 'view',
			modes: ['view'],
		};

		const payload = !{JSON.stringify(credentialPayloads)};

		const editor = new JSONEditor(container, options);
		editor.set(payload)

		editor.expandAll();

		const copyBtn = document.querySelector('#copy-button');

		copyBtn.addEventListener('click', () => {
			try {
				const json = editor.get();
				const text = JSON.stringify(json, null, 2);

				if (navigator.clipboard?.writeText) {
					navigator.clipboard.writeText(text);
				} else {
					const tempTextarea = document.createElement('textarea');
					tempTextarea.value = text;
					document.body.appendChild(tempTextarea);
					tempTextarea.select();
					document.execCommand('copy');
					document.body.removeChild(tempTextarea);
				}

				// Swap to "Copied ✓"
				copyBtn.classList.add('is-copied');

				// Reset back to "Copy ⧉" after 2 seconds
				window.clearTimeout(window.__copyResetTimer);
				window.__copyResetTimer = window.setTimeout(() => {
					copyBtn.classList.remove('is-copied');
				}, 2000);
			} catch (err) {
				console.error('Error getting JSON from editor:', err);
			}
		});

	script(src="/js/check-expired.js")
	script(src="/js/truncate-long-fields.js")
