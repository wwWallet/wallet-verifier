extends layout.pug

block head-styles
	link(rel="stylesheet" href="/styles/public-definitions.css")

block layout-content
	section
		.container.container__flexed
			header.page__header
				h2 #{locale.definitions.title}
				p.subtitle #{locale.definitions.subtitle}

			nav.definitions__grid(aria-label="Presentation request definitions")
				for definition in presentationRequests
					if definition._selectable === true
						a.card.def-card(href=`/verifier/public/definitions/request-credentials/${definition.id}`)
							.card-title #{definition.title}
							p.card-text #{definition.description}
					else
						a.card.def-card(href=`/verifier/public/definitions/presentation-request/${definition.id}`)
							.card-title #{definition.title}
							p.card-text #{definition.description}

				a.card.def-card.def-card--accent(href="/verifier/public/definitions/request-custom-credential")
					.card-title #{locale.definitions.customRequestTitle}
					p.card-text #{locale.definitions.customRequestDescription}
