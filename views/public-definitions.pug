extends layout.pug

block head-styles
	link(rel="stylesheet" href="/styles/public-definitions.css")

block layout-content
	section
		.container.container__flexed
			header.page__header
				h1 Present your Verifiable Credentials
				p.subtitle Choose a predefined request or create a custom one.

			nav.definitions__grid(aria-label="Presentation request definitions")
				for definition in presentationRequests
					if definition._selectable === true
						a.card.def-card(href=`/verifier/public/definitions/configurable-presentation-request/${definition.id}`)
							.card-title #{definition.title}
							p.card-text #{definition.description}
					else
						a.card.def-card(href=`/verifier/public/definitions/presentation-request/${definition.id}`)
							.card-title #{definition.title}
							p.card-text #{definition.description}

				a.card.def-card.def-card--accent(href="/verifier/public/definitions/edit-dcql-query")
					.card-title Custom Request
					p.card-text Import the DCQL query of your choice.
