footer#Footer.footer
	.footer__container
		.footer__grid
			section.footer__section(aria-labelledby="footer-services")
				h3#footer-services.footer__title #{locale.footer.services}
				ul.footer__list
					li
						img.icon(src="/icons/code.svg" alt="" aria-hidden="true")
						a(
							href="https://wwwallet.github.io/wallet-docs/"
							target="_blank"
							rel="noopener noreferrer"
						) #{locale.footer.documentation}

			section.footer__section(aria-labelledby="footer-contact")
				h3#footer-contact.footer__title #{locale.footer.contact}
				ul.footer__list
					li
						img.icon(src="/icons/github.svg" alt="" aria-hidden="true")
						a(
							href="https://github.com/wwWallet"
							target="_blank"
							rel="noopener noreferrer"
							aria-label="wwWallet on GitHub"
						) www.github.com/wwWallet
					li
						img.icon(src="/icons/email.svg" alt="" aria-hidden="true")
						a(
							href="mailto:info@wwWallet.org"
							aria-label="Email wwWallet"
						) info@wwWallet.org

		.footer__bottom
			.footer__meta
				small.footer__copyright
					span © #{new Date().getFullYear()} · wwWallet Verifier
